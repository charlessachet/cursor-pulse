{
  "name": "cursor-pulse",
  "displayName": "CursorPulse",
  "description": "Personal-first Cursor usage tracking in the status bar.",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorPulse.setSessionToken",
        "title": "CursorPulse: Set Session Token"
      },
      {
        "command": "cursorPulse.clearSessionToken",
        "title": "CursorPulse: Clear Session Token"
      },
      {
        "command": "cursorPulse.refresh",
        "title": "CursorPulse: Refresh",
        "icon": "$(sync)"
      },
      {
        "command": "cursorPulse.openSettings",
        "title": "CursorPulse: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "cursorPulse.exportDiagnostics",
        "title": "CursorPulse: Export Diagnostics",
        "icon": "$(output)"
      }
    ],
    "configuration": {
      "title": "CursorPulse",
      "properties": {
        "cursorPulse.pollMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "maximum": 240,
          "scope": "window",
          "description": "How often CursorPulse refreshes usage data, in minutes."
        },
        "cursorPulse.displayMode": {
          "type": "string",
          "default": "compact",
          "enum": [
            "compact"
          ],
          "scope": "window",
          "description": "How CursorPulse renders the status bar."
        },
        "cursorPulse.showUnlimitedActivity": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Show derived activity metrics for beyond-included usage in the tooltip."
        },
        "cursorPulse.warningThresholdSpend": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "scope": "window",
          "description": "Warn when extra spend reaches this fraction of the configured spend limit."
        },
        "cursorPulse.warningThresholdIncluded": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 1,
          "scope": "window",
          "description": "Warn when included usage remaining drops to this fraction of the included quota."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:vsix": "npm run compile && npx @vscode/vsce package --allow-missing-repository",
    "test": "npm run test:unit",
    "test:unit": "npm run compile && mocha --ui tdd ./out/test/suite/tokenParsing.test.js ./out/test/suite/usageMapper.test.js ./out/test/suite/usageService.test.js ./out/test/suite/statusBar.test.js ./out/test/suite/tooltip.test.js",
    "test:extension": "npm run compile && node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.6.1",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2"
  }
}
